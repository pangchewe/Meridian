10px] sm:text-xs md:text-sm font-normal tracking-wide transition-colors hover:text-[#E1E0CC] cursor-pointer cursor-scale\"\n                  id={`nav-item-${index}`}\n                >\n                  {item.label}\n                </button>\n              </li>\n            );\n          })}\n        </ul>\n      </div>\n    </nav>\n  );\n}\n"
