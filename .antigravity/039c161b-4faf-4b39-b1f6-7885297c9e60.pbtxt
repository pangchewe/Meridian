  file_change {
    absolute_path_uri: "file:///src/components/InteractiveWidget.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState, useEffect } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { X, Shield, ArrowRight, TrendingUp, Cpu, Info, CheckCircle2 } from \"lucide-react\";\n\ninterface InteractiveWidgetProps {\n  isOpen: boolean;\n  onClose: () => void;\n}\n\nexport function InteractiveWidget({ isOpen, onClose }: InteractiveWidgetProps) {\n  const [solAmount, setSolAmount] = useState<number>(100);\n  const [solPrice, setSolPrice] = useState<number>(150);\n  const [kaminoApy, setKaminoApy] = useState<number>(6.5);\n  const [strikePercentage, setStrikePercentage] = useState<number>(80);\n\n  // Derived financial simulations\n  const collateralValue = solAmount * solPrice;\n  const yearlyYield = collateralValue * (kaminoApy / 100);\n  const monthlyYield = yearlyYield / 12;\n\n  // Derive puts estimate: premium scales with strike price distance and price volatility\n  const strikePrice = solPrice * (strikePercentage / 100);\n  const protectionFloor = solAmount * strikePrice;\n  const estimatedPremiumYearlyPercent = (100 - strikePercentage) * 0.08 + 2.5; // e.g. 80% strike options premium ~ 4.1%\n  const monthlyPremiumPercent = estimatedPremiumYearlyPercent / 12 / 100;\n  const monthlyPremiumAmount = collateralValue * monthlyPremiumPercent;\n\n  // Calculation of self-paying hedge efficiency\n  const subsidyPercent = Math.min(100, (monthlyYield / Math.max(1, monthlyPremiumAmount)) * 100);\n  const netContribution = Math.max(0, monthlyPremiumAmount - monthlyYield);\n\n  // Auto scroll to lock body scrolling when open\n  useEffect(() => {\n    if (isOpen) {\n      document.body.style.overflow = \"hidden\";\n    } else {\n      document.body.style.overflow = \"unset\";\n    }\n    return () => {\n      document.body.style.overflow = \"unset\";\n    };\n  }, [isOpen]);\n\n  return (\n    <AnimatePresence>\n      {isOpen && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n          {/* Backdrop */}\n          <motion.div\n            initial={{ opacity: 0 }}\n            animate={{ opacity: 1 }}\n            exit={{ opacity: 0 }}\n            onClick={onClose}\n            className=\"absolute inset-0 bg-black/80 backdrop-blur-md\"\n            id=\"modal-backdrop\"\n          />\n\n          {/* Modal Content */}\n          <motion.div\n            initial={{ opacity: 0, scale: 0.95, y: 30 }}\n            animate={{ opacity: 1, scale: 1, y: 0 }}\n            exit={{ opacity: 0, scale: 0.95, y: 30 }}\n            transition={{ type: \"spring\", duration: 0.5, bounce: 0.15 }}\n            className=\"relative w-full max-w-4xl max-h-[90vh] overflow-y-auto bg-[#141414] border border-[#2A2A28] rounded-2xl shadow-2xl p-6 sm:p-8 text-[#E1E0CC]\"\n            id=\"simulation-modal\"\n          >\n            {/* Close Button */}\n            <button\n              onClick={onClose}\n              className=\"absolute top-4 right-4 text-gray-400 hover:text-white transition-colors p-1\"\n              title=\"Close Modal\"\n              id=\"close-modal-btn\"\n            >\n              <X size={20} />\n            </button>\n\n            {/* Header */}\n            <div className=\"flex items-center gap-3 mb-6\">\n              <div className=\"p-2.5 rounded-lg bg-primary/10 border border-primary/20 text-primary\">\n                <Shield size={22} className=\"text-primary\" />\n              </div>\n              <div>\n                <h3 className=\"text-xl sm:text-2xl font-bold tracking-tight uppercase\">Anti-Rekt Core dApp</h3>\n                <p className=\"text-xs text-gray-400 font-mono\">SOL PROTOCOL SIMULATOR v1.0.4</p>\n              </div>\n            </div>\n\n            {/* Content Grid */}\n            <div className=\"grid grid-cols-1 md:grid-cols-12 gap-6\">\n              {/* Left Column: Controls */}\n              <div className=\"md:col-span-5 space-y-5 bg-[#1C1C1A]/60 p-5 rounded-xl border border-[#232321]\">\n                <h4 className=\"text-xs uppercase font-mono tracking-wider text-primary border-b border-[#2A2A28] pb-2 mb-3\">\n                  COLLATERAL POSITION & TARGETS\n                </h4>\n\n                {/* SOL Amount Input */}\n                <div className=\"space-y-2\">\n                  <div className=\"flex justify-between text-xs font-mono\">\n                    <span className=\"text-gray-400\">SOL SUPPLY COLLATERAL</span>\n                    <span className=\"text-primary\">{solAmount.toLocaleString()} SOL</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"10\"\n                    max=\"1000\"\n                    step=\"10\"\n                    value={solAmount}\n                    onChange={(e) => setSolAmount(Number(e.target.value))}\n                    className=\"w-full accent-primary bg-black/40 h-1.5 rounded-lg appearance-none cursor-pointer\"\n                    id=\"sol-amount-slider\"\n                  />\n                  <div className=\"flex justify-between text-[11px] font-mono text-gray-500\">\n                    <span>10 SOL</span>\n                    <span>1,000 SOL</span>\n                  </div>\n                </div>\n\n                {/* SOL Price Input */}\n                <div className=\"space-y-2\">\n                  <div className=\"flex justify-between text-xs font-mono\">\n                    <span className=\"text-gray-400\">SOL INDEX PRICE</span>\n                    <span className=\"text-primary\">${solPrice} USD</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"50\"\n                    max=\"300\"\n                    step=\"5\"\n                    value={solPrice}\n                    onChange={(e) => setSolPrice(Number(e.target.value))}\n                    className=\"w-full accent-primary bg-black/40 h-1.5 rounded-lg appearance-none cursor-pointer\"\n                    id=\"sol-price-slider\"\n                  />\n                  <div className=\"flex justify-between text-[11px] font-mono text-gray-500\">\n                    <span>$50</span>\n                    <span>$300</span>\n                  </div>\n                </div>\n\n                {/* Kamino Base APY */}\n                <div className=\"space-y-2\">\n                  <div className=\"flex justify-between text-xs font-mono\">\n                    <span className=\"text-gray-400\">KAMINO BASE APY</span>\n                    <span className=\"text-emerald-400\">{kaminoApy}%</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"2\"\n                    max=\"15\"\n                    step=\"0.1\"\n                    value={kaminoApy}\n                    onChange={(e) => setKaminoApy(Number(e.target.value))}\n                    className=\"w-full accent-emerald-500 bg-black/40 h-1.5 rounded-lg appearance-none cursor-pointer\"\n                    id=\"kamino-apy-slider\"\n                  />\n                  <div className=\"flex justify-between text-[11px] font-mono text-gray-500\">\n                    <span>2.0%</span>\n                    <span>15.0%</span>\n                  </div>\n                </div>\n\n                {/* Liquidation Strike Options */}\n                <div className=\"space-y-2 font-sans\">\n                  <div className=\"flex justify-between text-xs font-mono\">\n                    <span className=\"text-gray-400\">PROTECTION STRIKE</span>\n                    <span className=\"text-primary\">{strikePercentage}% OF INDEX</span>\n                  </div>\n                  <input\n                    type=\"range\"\n                    min=\"65\"\n                    max=\"90\"\n                    step=\"1\"\n                    value={strikePercentage}\n                    onChange={(e) => setStrikePercentage(Number(e.target.value))}\n                    className=\"w-full accent-primary bg-black/40 h-1.5 rounded-lg appearance-none cursor-pointer\"\n                    id=\"strike-percentage-slider\"\n                  />\n                  <div className=\"flex justify-between text-[11px] font-mono text-gray-500\">\n                    <span>65% (Deep OTM)</span>\n                    <span>90% (Tight Floor)</span>\n                  </div>\n                </div>\n              </div>\n\n              {/* Right Column: Calculations & Results */}\n              <div className=\"md:col-span-7 flex flex-col justify-between space-y-6\">\n                <div className=\"grid grid-cols-2 gap-4\">\n                  {/* Kamino Yield Card */}\n                  <div className=\"bg-[#1C1C1A] border border-[#232321] rounded-xl p-4 flex flex-col justify-between\">\n                    <div>\n                      <div className=\"flex items-center gap-1.5 text-emerald-400 mb-1\">\n                        <TrendingUp size={14} />\n                        <span className=\"text-[10px] font-mono tracking-wider uppercase\">KAMINO FLOW</span>\n                      </div>\n                      <h5 className=\"text-xs text-gray-400 mb-2\">Simulated Yield Earner</h5>\n                    </div>\n                    <div>\n                      <div className=\"text-lg sm:text-xl font-bold text-emerald-400\">${monthlyYield.toFixed(2)}/mo</div>\n                      <div className=\"text-[10px] text-gray-500 font-mono tracking-wider\">${yearlyYield.toFixed(2)} / YEAR</div>\n                    </div>\n                  </div>\n\n                  {/* Derive PUT option Card */}\n                  <div className=\"bg-[#1C1C1A] border border-[#232321] rounded-xl p-4 flex flex-col justify-between\">\n                    <div>\n                      <div className=\"flex items-center gap-1.5 text-primary/80 mb-1\">\n                        <Cpu size={14} className=\"text-primary\" />\n                        <span className=\"text-[10px] font-mono tracking-wider uppercase text-primary\">DERIVE SHIELD</span>\n                      </div>\n                      <h5 className=\"text-xs text-gray-400 mb-2\">Estimated Put Option Premium</h5>\n                    </div>\n                    <div>\n                      <div className=\"text-lg sm:text-xl font-bold\">${monthlyPremiumAmount.toFixed(2)}/mo</div>\n                      <div className=\"text-[10px] text-gray-500 font-mono tracking-wider\">\n                        STRIKE: ${strikePrice.toFixed(1)} / SOL\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Self-paying Subsidy Progress & Net Fee */}\n                <div className=\"bg-black/40 p-5 rounded-xl border border-[#2A2A28] space-y-4\">\n                  <div className=\"flex justify-between items-center text-sm font-sans\">\n                    <span className=\"text-gray-400\">HEDGE SUBSIDY SHIELD LEVEL</span>\n                    <span className=\"font-bold text-primary font-mono\">{subsidyPercent.toFixed(1)}%</span>\n                  </div>\n\n                  {/* Progress bar container */}\n                  <div className=\"w-full h-3 border border-[#2A2A28] bg-black/40 rounded-full overflow-hidden p-0.5\">\n                    <motion.div\n                      className=\"h-full bg-primary rounded-full\"\n                      initial={{ width: 0 }}\n                      animate={{ width: `${subsidyPercent}%` }}\n                      transition={{ duration: 0.5 }}\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 pt-3 border-t border-[#232321] font-mono text-xs\">\n                    <div>\n                      <div className=\"text-gray-400\">LIQUIDATION SHIELD FLOOR</div>\n                      <div className=\"text-sm font-bold mt-1 text-primary\">\n                        ${protectionFloor.toLocaleString()} <span className=\"text-[10px] font-normal text-gray-500\">USD SECURED</span>\n                      </div>\n                    </div>\n                    <div>\n                      <div className=\"text-gray-400\">NET OUT-OF-POCKET</div>\n                      <div className=\"text-sm font-bold mt-1 text-primary\">\n                        {netContribution === 0 ? (\n                          <span className=\"text-emerald-400 flex items-center gap-1\">\n                            <CheckCircle2 size={13} className=\"text-emerald-400\" />\n                            100% FREE (SELF-PAID)\n                          </span>\n                        ) : (\n                          <span>${netContribution.toFixed(2)}/mo</span>\n                        )}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"bg-[#1F1E19]/40 border border-primary/10 rounded-xl p-4 flex gap-3 text-xs text-gray-400 leading-normal\">\n                  <Info size={18} className=\"text-primary mt-0.5 shrink-0\" />\n                  <div>\n                    Supply Sol into <span className=\"text-primary\">Kamino Finance</span> automatically activates option underwriting inside <span className=\"text-primary\">Derive Protocol</span>. The premiums are directly synchronized atomically, completely preserving your primary collateral parameters and generating risk-free exposure limits against sudden black swan dips.\n                  </div>\n                </div>\n\n                {/* Confirm Shield Activating */}\n                <button\n                  onClick={() => {\n                    alert(`Self-Paying protection of ${solAmount} SOL initiated successfully. Liquidation protection floor established at $${strikePrice.toFixed(2)}/SOL.`);\n                  }}\n                  className=\"w-full bg-primary hover:bg-primary/90 text-black font-semibold uppercase font-sans py-3.5 px-6 rounded-lg text-sm transition-all duration-300 flex items-center justify-center gap-2 group tracking-wide\"\n                  id=\"confirm-shield-btn\"\n                >\n                  DEPLOY SELF-PAYING PROTECTION\n                  <ArrowRight size={16} className=\"transition-transform group-hover:translate-x-1\" />\n                </button>\n              </div>\n            </div>\n          </motion.div>\n        </div>\n      )}\n    </AnimatePresence>\n  );\n}\n"
    }
